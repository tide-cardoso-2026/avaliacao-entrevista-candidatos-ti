# Arquivos binários acidentais em prompts
prompts/**/*.zip

# Dados locais sensíveis (CVs, transcrições, perfis, JDs reais) — manter só .gitkeep
data/candidates/*
!data/candidates/.gitkeep
data/clients/*
!data/clients/.gitkeep
data/interviews/*
!data/interviews/.gitkeep
data/job_description/*
!data/job_description/.gitkeep
