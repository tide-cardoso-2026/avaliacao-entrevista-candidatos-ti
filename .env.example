# Copie para .env e preencha (nunca commite .env com chaves reais)
OPENROUTER_API_KEY=
# Opcional: OpenAI direto
OPENAI_API_KEY=

OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
DEFAULT_MODEL=meta-llama/llama-3-8b-instruct

MODEL_ASSISTANTS=meta-llama/llama-3-8b-instruct
# Tiers de assistentes (default = mesmo ID que MODEL_ASSISTANTS). Ajuste por perfil: tecnico vs soft vs lideranca vs psicologas.
MODEL_ASSISTANTS_TECHNICAL=meta-llama/llama-3-8b-instruct
MODEL_ASSISTANTS_SOFT=meta-llama/llama-3-8b-instruct
MODEL_ASSISTANTS_LEADERSHIP=meta-llama/llama-3-8b-instruct
MODEL_ASSISTANTS_PSYCH=meta-llama/llama-3-8b-instruct
MODEL_MIDDLE=meta-llama/llama-3-8b-instruct
# Mesmo modelo por padrao (barato). Para CTO premium com creditos: ex. anthropic/claude-3.5-sonnet
MODEL_CTO=meta-llama/llama-3-8b-instruct
# Selecao dinamica de agentes (meta). Pode ser um modelo maior que MODEL_ASSISTANTS para roteamento mais estavel.
MODEL_META=meta-llama/llama-3-8b-instruct

# Paralelismo na camada de assistentes (ThreadPoolExecutor)
# AGENT_ENGINE_MAX_WORKERS=8
# Tamanho maximo da KB injetada por assistente (caracteres)
# TECHNICAL_KB_MAX_CHARS=24000

# Limite de tokens por resposta (menor = menos custo)
# MAX_TOKENS=2048

LOG_LEVEL=INFO

# API FastAPI (uvicorn): se definido, todas as rotas exceto GET /health exigem header X-API-Key
# API_KEY=
# Requisicoes por minuto por IP (slowapi)
# API_RATE_LIMIT_PER_MINUTE=60

# Log de tokens por chamada LLM (quando a API retornar usage)
# LLM_LOG_TOKEN_USAGE=true   # só aparece com LOG_LEVEL=DEBUG (CLI usa só linhas do pipeline)

# Mensagens de UI: fallback por IA para textos de log sem mapeamento (custo extra; default desligado)
# HUMANIZE_UI_WITH_LLM=false

# SQLite (padrao: data/history.db)
# DATABASE_URL=sqlite:///D:/caminho/data/history.db

# LinkedIn opcional (Proxycurl)
# PROXYCURL_API_KEY=

# Pasta da base de perguntas técnicas (padrao: data/technical-questions)
# TECHNICAL_QUESTIONS_DIR=D:/caminho/data/technical-questions

# Scorecard estruturado (API): exige evidencias com justificativa minima
# SCORECARD_REQUIRE_EVIDENCE=true
# MIN_EVIDENCE_JUSTIFICATION_CHARS=20
# GOLDEN_DATASET_PATH=data/golden_dataset/golden_answers.json
